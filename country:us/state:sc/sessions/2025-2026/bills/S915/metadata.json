{
  "legislative_session": "2025-2026",
  "identifier": "S 915",
  "title": "Medicaid Provider and Recipient Fraud",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 43-7-60, RELATING TO THE PROHIBITION OF FALSE CLAIMS, STATEMENTS, OR REPRESENTATION BY MEDICAL PROVIDERS, SO AS TO CREATE TIERED VIOLATIONS AND PENALTIES FOR THIS SECTION AND PROVIDE FOR THE USE OF CONSENT AGREEMENTS; BY AMENDING SECTION 43-7-70, RELATING TO THE PROHIBITION OF FALSE STATEMENTS OR REPRESENTATION ON APPLICATIONS FOR ASSISTANCE, SO AS TO CREATE TIERED VIOLATIONS AND PENALTIES FOR THIS SECTION AND PROVIDE FOR THE USE OF CONSENT AGREEMENTS; AND BY AMENDING SECTION 43-7-90, RELATING TO THE ENFORCEMENT OF SECTIONS 43-7-60 TO 43-7-80, SO AS TO AUTHORIZE THE ATTORNEY GENERAL TO ISSUE ADMINISTRATIVE SUBPOENAS AND OTHER APPROPRIATE ACTIONS."
    }
  ],
