{
  "legislative_session": "2025-2026",
  "identifier": "H 4767",
  "title": "Physician Noncompete Contract Prohibition",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING CHAPTER 9 TO TITLE 41 SO AS TO PROHIBIT NONCOMPETE CLAUSES IN PHYSICIAN CONTRACTS, TO PROTECT PATIENT FREEDOM OF CHOICE, TO DEFINE IMPERMISSIBLE RESTRICTIONS ON PHYSICIAN PRACTICE, TO ALLOW CERTAIN RECOUPMENT OF EXPENSES AND PROTECTION OF LEGITIMATE BUSINESS INTERESTS, AND TO PROVIDE FOR APPLICABILITY."
    }
  ],
