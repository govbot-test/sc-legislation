{
  "legislative_session": "2025-2026",
  "identifier": "H 3569",
  "title": "Domestic violence in rental properties",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 27-40-350 SO AS TO PROVIDE THAT RESIDENTIAL TENANTS WHO ARE VICTIMS OF CERTAIN DOMESTIC VIOLENCE OFFENSES MAY TERMINATE A RENTAL AGREEMENT AND TO PROVIDE FOR NECESSARY REQUIREMENTS; AND BY AMENDING SECTION 27-40-210, RELATING TO DEFINITIONS, SO AS TO DEFINE TERMS. - RATIFIED TITLE"
    }
  ],
