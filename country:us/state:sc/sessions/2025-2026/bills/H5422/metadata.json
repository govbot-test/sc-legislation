  "legislative_session": "2025-2026",
  "identifier": "H 5422",
  "title": "Motor fuel user fee suspension",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A JOINT RESOLUTION TO SUSPEND THE IMPOSITION OF THE USER FEE ON GASOLINE AND DIESEL FUEL AND THE IMPOSITION OF THE ROAD TAX FOR THIRTY DAYS AND FOR AN AUTOMATIC EXTENSION FOR ANOTHER THIRTY DAYS IF THE AVERAGE PRICE OF GASOLINE HAS NOT FALLEN BY FIFTEEN PERCENT AT THE END OF THE INITIAL THIRTY-DAY PERIOD."
    }
  ],
