{
  "legislative_session": "2025-2026",
  "identifier": "H 5096",
  "title": "Lab grown/cultured meat",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING ARTICLE 5 OF CHAPTER 17, TITLE 47, RELATING TO MISREPRESENTING PRODUCTS THAT ARE CELL-CULTURED MEAT, SO AS TO PROVIDE IT IS UNLAWFUL TO MANUFACTURE, SELL, OR DISTRIBUTE ARTIFICIAL OR CELL-CULTIVATED FOOD PRODUCTS IN THIS STATE, TO MAKE A TECHNICAL CHANGE, TO PROVIDE ADDITIONAL PENALTIES FOR VIOLATIONS OF THIS ARTICLE, AND TO PROVIDE THE DEPARTMENT OF AGRICULTURE MAY PROMULGATE REGULATIONS TO IMPLEMENT THE PROVISIONS OF THIS ARTICLE."
    }
  ],
