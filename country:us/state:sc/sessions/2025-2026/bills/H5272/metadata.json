  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 34-3-120 SO AS TO REQUIRE FINANCIAL INSTITUTIONS TO VERIFY THAT INDIVIDUALS ARE CITIZENS OF THE UNITED STATES BEFORE WIRING OR REMITTING FUNDS TO FOREIGN COUNTRIES, AND TO EITHER REQUIRE A FEE OR PROHIBIT THE TRANSFER IF THE INDIVIDUAL IS NOT A UNITED STATES CITIZEN."
    }
  ],
