  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 11-35-5350 SO AS TO REQUIRE A PUBLIC ENTITY ENTERING INTO A CONTRACT FOR A PUBLIC WORKS PROJECT OR FOR THE PURCHASE OF MATERIALS FOR A PUBLIC WORKS PROJECT MUST INCLUDE IN THE CONTRACT A REQUIREMENT THAT ANY IRON OR STEEL PRODUCT PERMANENTLY INCORPORATED IN THE PROJECT BE PRODUCED IN THE UNITED STATES, AND TO PROVIDE EXCEPTIONS."
    }
  ],
