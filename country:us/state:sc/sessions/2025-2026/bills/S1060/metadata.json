{
  "legislative_session": "2025-2026",
  "identifier": "S 1060",
  "title": "Educator Safety and Classroom Authority Act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING ARTICLE 14 TO CHAPTER 63, TITLE 59, SO AS TO DEFINE TERMS RELATED TO EDUCATOR SAFETY AND CLASSROOM AUTHORITY; TO INCLUDE RELEVANT EDUCATOR CLASSROOM AUTHORITY; TO PROVIDE FOR REFERRAL, REMOVAL, AND ADMINISTRATIVE FOLLOW-UP PROCESSES; TO PROVIDE PROTECTIONS FOR EDUCATORS, ADMINISTRATORS, AND STAFF; TO CREATE DUTIES FOR THE STATE BOARD OF EDUCATION; AND TO REQUIRE LOCAL DISTRICT BOARD OF TRUSTEES TO REVISE THEIR STUDENT AND STAFF CODES OF CONDUCT TO CONFORM WITH THIS ARTICLE WITHIN ONE YEAR OF THE DATE OF ENACTMENT."
    }
  ],
