  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 1-7-550 SO AS TO PROVIDE THAT FOR TWO YEARS AFTER LEAVING OFFICE, A SOLICITOR MAY NOT REPRESENT A CLIENT FOR A FEE OR APPEAR IN COURT IN THE DISTRICT FROM WHICH HE WAS ELECTED."
    }
  ],
