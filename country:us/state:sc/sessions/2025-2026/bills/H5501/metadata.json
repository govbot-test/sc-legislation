  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO REJECT THE SUPREME COURT OF THE UNITED STATES OBERGEFELL DECISION AND TO CALL ON THE SUPREME COURT TO REVERSE OBERGEFELL AND RESTORE THE NATURAL LAW DEFINITION OF MARRIAGE, A UNION OF ONE MAN AND ONE WOMAN AND TO INSIST ON RESTORING THE ISSUE OF MARRIAGE AND ENFORCEMENT OF ALL LAWS PERTAINING TO MARRIAGE BACK TO THE SEVERAL STATES AND THE PEOPLE."
    }
  ],
