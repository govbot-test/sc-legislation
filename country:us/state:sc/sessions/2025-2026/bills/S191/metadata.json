  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 17-13-150, RELATING TO THE REQUIREMENT THAT A PERSON SERVED A SEARCH WARRANT MUST BE FURNISHED A COPY OF THE WARRANT AND THE SUPPORTING AFFIDAVIT, SO AS TO REMOVE THE AFFIDAVIT REQUIREMENT AND PROVIDE FOR DELIVERY OF A COPY OF THE INVENTORY IF DEMANDED BY THE PERSON UPON WHOM THE SEARCH WARRANT IS SERVED."
    }
  ],
