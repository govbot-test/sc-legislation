  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 30-2-60 SO AS TO PROVIDE THAT EVICTION FILINGS AND RECORDS THAT INCLUDE PERSONAL INFORMATION OF A DEFENDANT ARE AUTOMATICALLY REMOVED FROM THE PUBLIC INDEX AFTER FIVE YEARS IF NO SUBSEQUENT EVICTIONS OR EJECTMENTS HAVE OCCURRED."
    }
  ],
