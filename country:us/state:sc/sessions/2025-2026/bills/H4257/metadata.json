{
  "legislative_session": "2025-2026",
  "identifier": "H 4257",
  "title": "Excused student absences",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND SECTION 59-1-462 OF THE SOUTH CAROLINA CODE OF LAWS, RELATING TO EXCUSED SCHOOL ABSENCES FOR CAREER AND TECHNICAL STUDENT ORGANIZATION EXPERIENCES, SO AS TO PROVIDE THAT STUDENTS PARTICIPATING IN ANY INTERSCHOLASTIC ACTIVITY AUTHORIZED BY THE SCHOOL DISTRICT ARE ELIGIBLE FOR EXCUSED ABSENCES, REGARDLESS OF WHETHER THE ACTIVITY IS SANCTIONED BY THE SOUTH CAROLINA HIGH SCHOOL LEAGUE OR ANY OTHER GOVERNING ENTITY, AND TO REQUIRE THAT STUDENTS BE IN ACADEMIC GOOD STANDING TO QUALIFY FOR SUCH EXCUSED ABSENCES. - RATIFIED TITLE"
    }
  ],
