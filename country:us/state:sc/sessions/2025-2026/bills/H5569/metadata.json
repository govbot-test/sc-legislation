{
  "legislative_session": "2025-2026",
  "identifier": "H 5569",
  "title": "Farm Aid and Resiliency Grant Fund",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 48-62-80 SO AS TO CREATE THE \"SOUTH CAROLINA FARM AID AND RESILIENCY GRANT FUND\" AND TO PROVIDE REQUIREMENTS REGARDING THIS FUND; TO REQUIRE THE OFFICE OF RESILIENCE TO ADMINISTER THE FUND AND, IN CONSULTATION WITH THE DEPARTMENT OF AGRICULTURE, DEVELOP CRITERIA, PROCEDURES, AND AWARD GUIDELINES FOR ADMINISTERING THE GRANT PROGRAM; AND TO APPROPRIATE FIFTY MILLION DOLLARS TO THE FUND FROM THE CONTINGENCY RESERVE FUND."
    }
  ],
