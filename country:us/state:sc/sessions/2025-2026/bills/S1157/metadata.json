  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO REQUEST THAT THE DEPARTMENT OF TRANSPORTATION NAME THE PORTION OF CATES BAY HIGHWAY FROM ITS INTERSECTION WITH HIGHWAY 134 TO ITS INTERSECTION WITH HIGHWAY 804 IN HORRY COUNTY \"BOBBY LONG MARTIN HIGHWAY\" AND ERECT APPROPRIATE MARKERS OR SIGNS AT THIS LOCATION CONTAINING THE DESIGNATION."
    }
  ],
