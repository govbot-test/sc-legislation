  "legislative_session": "2025-2026",
  "identifier": "S 449",
  "title": "Collaborative Practice Agreements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 40-43-30, RELATING TO DEFINITIONS FOR THE SOUTH CAROLINA PHARMACY PRACTICE ACT, SO AS TO PROVIDE A DEFINITION FOR COLLABORATIVE PRACTICE AGREEMENTS; BY ADDING SECTION 40-43-245 SO AS TO AUTHORIZE PHARMACISTS AND PHYSICIANS TO ENTER INTO COLLABORATIVE PRACTICE AGREEMENTS; BY AMENDING SECTION 40-47-20, RELATING TO DEFINITIONS FOR PHYSICIANS AND MISCELLANEOUS HEALTHCARE PROFESSIONALS, SO AS TO PROVIDE A DEFINITION FOR COLLABORATIVE PRACTICE AGREEMENTS; BY ADDING SECTION 40-47-205 SO AS TO AUTHORIZE PHYSICIANS AND PHARMACISTS TO ENTER INTO COLLABORATIVE PRACTICE AGREEMENTS; AND TO REQUIRE THE STATE BOARD OF PHARMACY AND THE STATE BOARD OF MEDICAL EXAMINERS TO PROMULGATE REGULATIONS GOVERNING THE USE OF COLLABORATIVE PRACTICE AGREEMENTS AND TO PROVIDE THAT COLLABORATIVE PRACTICE AGREEMENTS MAY NOT BE IMPLEMENTED UNTIL AFTER THE REGULATIONS ARE EFFECTIVE. - RATIFIED TITLE"
    }
  ],
