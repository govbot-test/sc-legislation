{
  "legislative_session": "2025-2026",
  "identifier": "H 4755",
  "title": "Judicial Selection Reform",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTIONS 2-19-5, 2-19-20, 2-19-30, 2-19-35, 2-19-50, 2-19-60 AND 2-19-70, ALL RELATING TO THE SOUTH CAROLINA JUDICIAL MERIT SELECTION COMMISSION SCREENING AND ELECTION OF JUSTICES AND JUDGES, SO AS TO REVISE THE STAFFING AND APPOINTMENT PROCESS OF THE COMMISSION AND TRANSFER THAT AUTHORITY TO THE GOVERNOR, TO PROHIBIT SITTING MEMBERS OF THE GENERAL ASSEMBLY AND CERTAIN FAMILY MEMBERS FROM SERVING ON THE COMMISSION, TO PROHIBIT THE COMMISSION FROM CONSIDERING DIVERSITY, EQUITY, AND INCLUSION CRITERIA ALONG WITH OTHER SIMILAR CRITERIA, AND TO MAKE CONFORMING CHANGES."
    }
  ],
