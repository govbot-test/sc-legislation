  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ENACTING THE \"HEIRS' PROPERTY TAX RELIEF ACT\" BY AMENDING SECTION 12-37-3150, RELATING TO DETERMINING WHEN AN ASSESSABLE TRANSFER OF INTEREST OCCURS, SO AS TO EXCLUDE TRANSFERS MADE TO QUALIFIED FAMILY MEMBERS TO CLEAR THE TITLE OF HEIRS' PROPERTY. - RATIFIED TITLE"
    }
  ],
