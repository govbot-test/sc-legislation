  "abstracts": [
    {
      "note": "description",
      "abstract": "A JOINT RESOLUTION PROPOSING AN AMENDMENT TO SECTION 7, ARTICLE III OF THE CONSTITUTION OF SOUTH CAROLINA, 1895, RELATING TO THE QUALIFICATIONS OF SENATORS AND MEMBERS OF THE HOUSE OF REPRESENTATIVES, SO AS TO LIMIT SENATORS TO SERVING NO MORE THAN THREE TERMS IN OFFICE AND TO LIMIT MEMBERS OF THE HOUSE OF REPRESENTATIVES TO SERVING NO MORE THAN SIX TERMS IN OFFICE."
    }
  ],
