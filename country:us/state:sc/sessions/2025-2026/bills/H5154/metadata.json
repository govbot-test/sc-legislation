  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A HOUSE RESOLUTION TO EXPRESS THE SUPPORT OF THE SOUTH CAROLINA HOUSE OF REPRESENTATIVES FOR THE PRESIDENT OF THE UNITED STATES IN HIS EFFORTS TO DEVOLVE EDUCATIONAL AUTHORITY FROM THE UNITED STATES DEPARTMENT OF EDUCATION TO THE STATES AND TO ELIMINATE THE UNITED STATES DEPARTMENT OF EDUCATION, AND TO MEMORIALIZE THE CONGRESS OF THE UNITED STATES TO SUPPORT AND COOPERATE WITH THESE EFFORTS THROUGH NECESSARY LEGISLATIVE ACTION AND FAITHFUL EXECUTION."
    }
  ],
