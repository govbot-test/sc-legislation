  "identifier": "H 5134",
  "title": "Condemnation of Racism",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO AFFIRM THE UNEQUIVOCAL OPPOSITION TO RACISM, HATRED, AND DEHUMANIZING RHETORIC IN ANY FORM, FROM ANY SOURCE, AT ANY LEVEL OF GOVERNMENT OR PUBLIC LIFE AND FURTHER AFFIRM THAT LEADERSHIP CARRIES RESPONSIBILITY, AND THAT THOSE ENTRUSTED WITH PUBLIC INFLUENCE MUST STRIVE TO ELEVATE OUR DISCOURSE RATHER THAN DEGRADE IT, RECOGNIZING THAT WORDS CAN EITHER HEAL OR HARM."
    }
  ],
