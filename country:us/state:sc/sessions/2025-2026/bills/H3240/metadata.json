  "legislative_session": "2025-2026",
  "identifier": "H 3240",
  "title": "School board proxy vote ban",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 59-19-75 SO AS TO PROVIDE SCHOOL DISTRICT TRUSTEES MAY NOT DELEGATE THEIR AUTHORITY OR APPOINT PROXIES TO VOTE OR OTHERWISE ACT ON THEIR BEHALF, TO PROVIDE ANY ACTIONS TAKEN BY SUCH DELEGATIONS OR PROXIES ARE NULL AND VOID AB INITIO, AND TO PROVIDE TRUSTEES WHO DELEGATE THEIR AUTHORITY OR APPOINT PROXIES TO VOTE OR OTHERWISE ACT FOR THEM ARE SUBJECT TO REMOVAL BY THE GOVERNOR."
    }
  ],
