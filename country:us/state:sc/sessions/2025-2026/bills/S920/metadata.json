  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING ARTICLE 25 TO CHAPTER 71, TITLE 38 SO AS TO PROVIDE CIRCUMSTANCES THAT MUST BE CONSIDERED WHEN A HEALTH INSURER USES ARTIFICIAL INTELLIGENCE TO MAKE DETERMINATIONS RELATING TO PRIOR AUTHORIZATIONS, TO PROVIDE CERTAIN DISCLOSURES TO ENROLLEES, AND TO PROVIDE DISCIPLINARY ACTIONS FOR VIOLATIONS."
    }
  ],
