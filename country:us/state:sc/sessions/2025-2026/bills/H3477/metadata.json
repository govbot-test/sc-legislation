{
  "legislative_session": "2025-2026",
  "identifier": "H 3477",
  "title": "Maximum potential employment benefits",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 41-35-50, RELATING TO THE MAXIMUM UNEMPLOYMENT INSURANCE BENEFITS ALLOWED IN A BENEFIT YEAR, SO AS TO BASE THE DURATION OF UNEMPLOYMENT BENEFITS ALLOWED ON SEASONALLY ADJUSTED STATEWIDE UNEMPLOYMENT RATES, TO PROVIDE REQUIREMENTS FOR CALCULATING THE RATES, AND TO PROVIDE THE DEPARTMENT OF EMPLOYMENT AND WORKFORCE SHALL PROMULGATE CERTAIN RELATED REGULATIONS; AND BY AMENDING SECTION 41-35-120, RELATING TO DISQUALIFICATION FOR BENEFITS."
    }
  ],
