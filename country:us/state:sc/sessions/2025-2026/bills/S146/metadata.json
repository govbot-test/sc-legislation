{
  "legislative_session": "2025-2026",
  "identifier": "S 146",
  "title": "Senator Roger A. Nutt Act, resident's rights in long-term care",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ENACTING THE \"SENATOR ROGER A. NUTT ACT\" BY AMENDING SECTION 44-81-40, RELATING TO RIGHTS OF RESIDENTS OF LONG-TERM CARE FACILITIES, SO AS TO PROVIDE THAT RESIDENTS MAY DESIGNATE UP TO THREE PEOPLE WHO ARE PERMITTED TO VISIT THE RESIDENT IN THE EVENT THAT ACCESS TO THE FACILITY IS LIMITED OR PROHIBITED DUE TO A DECLARED STATE OF EMERGENCY ARISING FROM A DISASTER OR PUBLIC HEALTH EMERGENCY. - RATIFIED TITLE"
    }
  ],
