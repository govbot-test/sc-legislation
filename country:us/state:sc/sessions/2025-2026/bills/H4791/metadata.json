{
  "legislative_session": "2025-2026",
  "identifier": "H 4791",
  "title": "Drug acquisition cost surveys and reimbursement guidelines",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 40-43-60, RELATING TO MISCELLANEOUS REQUIREMENTS CONCERNING PHARMACIES AND THE PRACTICE OF PHARMACY, SO AS TO PROVIDE PHARMACIES PERMITTED IN THIS STATE SHALL COOPERATE WITH FEDERAL AND STATE ACQUISITION COST SURVEYS; AND BY ADDING SECTION 38-71-2270 SO AS TO PROVIDE GUIDELINES FOR PHARMACY BENEFITS MANAGERS WHEN REIMBURSING PHARMACIES AND PHARMACISTS FOR PRESCRIPTION DRUGS AND PHARMACY SERVICES."
    }
  ],
