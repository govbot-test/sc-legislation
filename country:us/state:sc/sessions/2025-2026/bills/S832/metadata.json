{
  "legislative_session": "2025-2026",
  "identifier": "S 832",
  "title": "University Campus Events Zoning",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 53-1-20, RELATING TO COLLEGE AND UNIVERSITY CAMPUSES EXEMPT FROM THE PROHIBITION ON SUNDAY PUBLIC SPORTS, SO AS TO DEFINE TERMS PERTAINING TO CAMPUS EVENTS AND LAND USE APPROVAL, TO PROVIDE THAT NO COUNTY OR MUNICIPALITY MAY PROHIBIT, RESTRICT, CONDITION, DELAY, OR REQUIRE LAND USE APPROVAL FOR EVENTS HELD ON THE CAMPUS OF A STATE-SUPPORTED INSTITUTION OF HIGHER LEARNING BASED ON ZONING ORDINANCES OR LAND USE CLASSIFICATIONS, AND TO CLARIFY THE APPLICATION OF GENERALLY APPLICABLE SAFETY LAWS. - RATIFIED TITLE"
    }
  ],
