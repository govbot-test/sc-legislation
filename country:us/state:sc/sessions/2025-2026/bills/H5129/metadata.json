  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO REQUEST THE DEPARTMENT OF TRANSPORTATION NAME THE PORTION OF UNITED STATES HIGHWAY 501 FROM ITS INTERSECTION WITH MEDLEN PARKWAY TO ITS INTERSECTION WITH MILL POND ROAD IN THE CITY OF CONWAY IN HORRY COUNTY \"CHUCK JORDAN HIGHWAY\" AND PLACE APPROPRIATE SIGNS OR MARKERS AT THIS LOCATION CONTAINING THESE WORDS."
    }
  ],
