  "abstracts": [
    {
      "note": "description",
      "abstract": "A JOINT RESOLUTION TO CREATE THE \"PRESCRIPTION MEDICINE STUDY COMMITTEE\" TO EXAMINE AND RECOMMEND INNOVATIVE METHODS TO REDUCE COSTS FOR PRESCRIPTION MEDICINES CONSIDERED CRITICAL TO SOUTH CAROLINA CITIZENS; TO PROVIDE FOR THE MEMBERSHIP, DUTIES, AND RESPONSIBILITIES OF THE COMMITTEE; AND TO REQUIRE A REPORT OF FINDINGS AND RECOMMENDATIONS TO THE GENERAL ASSEMBLY."
    }
  ],
