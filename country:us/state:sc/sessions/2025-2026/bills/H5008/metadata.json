  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS SO AS TO ENACT THE \"SOUTH CAROLINA FOSTERING FUTURES ACT\" BY ADDING ARTICLE 11 TO CHAPTER 111, TITLE 59, SO AS TO REQUIRE PUBLIC INSTITUTIONS OF HIGHER EDUCATION TO WAIVE TUITION AND FEES FOR CERTAIN CURRENT AND FORMER FOSTER YOUTH; TO PROVIDE ELIGIBILITY CRITERIA AND LIMITS; AND TO REQUIRE INSTITUTIONAL SUPPORT AND REPORTING."
    }
  ],
