  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 44-55-20, RELATING TO WATER, SEWAGE, WASTE DISPOSAL DEFINITIONS, SO AS TO DEFINE \"FLUORIDE\"; AND BY ADDING SECTION 44-55-35 SO AS TO PROHIBIT THE ADDITION OF FLUORIDE TO A PUBLIC WATER SYSTEM OR TO WATER THAT WILL BE INTRODUCED INTO A PUBLIC WATER SYSTEM."
    }
  ],
