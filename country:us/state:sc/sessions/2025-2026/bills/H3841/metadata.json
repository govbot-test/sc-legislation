  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "AN ACT TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 12-43-220, RELATING TO ASSESSMENT RATIOS, SO AS TO PROVIDE THAT UNDER CERTAIN CIRCUMSTANCES, PROPERTY RECEIVING THE FOUR PERCENT ASSESSMENT RATIO SHALL CONTINUE AT FOUR PERCENT WHEN THE OWNER DIES; AND BY ADDING SECTION 12-37-460 SO AS TO PROVIDE THAT UNDER CERTAIN CIRCUMSTANCES PROPERTY TAX EXEMPTIONS SHALL CONTINUE TO APPLY WHEN THE OWNER DIES. - RATIFIED TITLE"
    }
  ],
