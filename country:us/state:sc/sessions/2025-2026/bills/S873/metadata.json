  "abstracts": [
    {
      "note": "description",
      "abstract": "A SENATE RESOLUTION TO RECOGNIZE AND SUPPORT \"INTRODUCE A GIRL TO ENGINEERING DAY\"; TO ENCOURAGE THE PARTICIPATION OF STUDENTS, EDUCATORS, ENGINEERS, FAMILIES, AND COMMUNITY PARTNERS ACROSS THE STATE; AND TO DECLARE TUESDAY, FEBRUARY 24, 2026, AS \"INTRODUCE A GIRL TO ENGINEERING DAY\" IN SOUTH CAROLINA."
    }
  ],
