  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 33-14-107, RELATING TO UNKNOWN CLAIMS AGAINST DISSOLVED CORPORATIONS, SO AS TO BAR ENFORCEMENT PROCEEDINGS AGAINST DISSOLVED CORPORATIONS UNLESS THE CLAIMANT COMMENCES A PROCEEDING WITHIN FIVE YEARS AFTER THE CORPORATION'S NOTICE OF DISSOLUTION."
    }
  ],
