  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO REQUEST THE DEPARTMENT OF TRANSPORTATION NAME THE PORTION OF PLATT SPRINGS ROAD IN THE TOWN OF SPRINGDALE IN LEXINGTON COUNTY FROM ITS INTERSECTION WITH RAINBOW DRIVE TO ITS INTERSECTION WITH WATTLING ROAD \"MAYOR PAT G. SMITH MEMORIAL ROAD\" AND ERECT APPROPRIATE MARKERS OR SIGNS AT THIS LOCATION CONTAINING THESE WORDS."
    }
  ],
