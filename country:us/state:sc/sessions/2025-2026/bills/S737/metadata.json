{
  "legislative_session": "2025-2026",
  "identifier": "S 737",
  "title": "Dialysate and Dialysis Product Safety",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY AMENDING SECTION 15-73-10, RELATING TO LIABILITY OF SELLER FOR DEFECTIVE PRODUCT, SO AS TO INCLUDE CHINESE-MADE DIALYSATE OR DIALYSIS PRODUCTS ARE PER SE DEEMED TO BE IN A DEFECTIVE CONDITION AND UNREASONABLY DANGEROUS; BY ADDING SECTION 39-24-70 SO AS TO MAKE IT UNLAWFUL TO SUBSTITUTE WITH CHINESE-MADE PRODUCTS; AND BY ADDING SECTION 44-53-60 SO AS TO MAKE IT UNLAWFUL FOR DIALYSATE OR DIALYSIS PRODUCT TO BE FROM CHINA OR TO CONTAIN ALUMINUM."
    }
  ],
