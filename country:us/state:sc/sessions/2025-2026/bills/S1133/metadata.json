  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO REQUEST THAT THE DEPARTMENT OF TRANSPORTATION NAME THE PORTION OF HIGHWAY 78 FROM THE BAMBERG COUNTY LINE TO THE AIKEN COUNTY LINE THE \"LONNIE HOSEY PURPLE HEART HIGHWAY\" AND ERECT APPROPRIATE MARKERS OR SIGNS AT THIS LOCATION CONTAINING THE DESIGNATION."
    }
  ],
