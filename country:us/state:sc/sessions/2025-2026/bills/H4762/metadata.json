  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 59-1-335 SO AS TO AUTHORIZE SCHOOL DISTRICTS AND CHARTER SCHOOLS TO IMPLEMENT CERTAIN VOLUNTEER SCHOOL CHAPLAIN POLICIES; AND BY ADDING SECTION 59-1-485 SO AS TO PROVIDE FOR THE DISPLAY OF THE TEN COMMANDMENTS AND OTHER HISTORICAL DOCUMENTS IN PUBLIC SCHOOL AND POSTSECONDARY CLASSROOMS."
    }
  ],
