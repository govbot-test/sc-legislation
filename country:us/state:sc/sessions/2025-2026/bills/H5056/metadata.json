  "identifier": "H 5056",
  "title": "Home Repair Consumer Protection Act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ENACTING THE \"HOME REPAIR CONSUMER PROTECTION ACT\" BY ADDING CHAPTER 31 TO TITLE 37 SO AS TO REQUIRE WRITTEN AND SIGNED CONTRACTS FOR CERTAIN HOME REPAIR SERVICES, TO PROVIDE CERTAIN RIGHTS AND PROTECTIONS OF HOMEOWNERS WHO ENTER INTO HOME REPAIR AGREEMENTS WITH HEIGHTENED PROTECTIONS FOR ELDERLY HOMEOWNERS, TO CREATE THE OFFENSE OF HOME REPAIR FRAUD AND TO ESTABLISH PENALTIES, AND TO ESTABLISH CERTAIN PROHIBITED ACTS OF CONTRACTORS OR THEIR AGENTS WHICH CONSTITUTE AN UNFAIR TRADE PRACTICE."
    }
  ],
