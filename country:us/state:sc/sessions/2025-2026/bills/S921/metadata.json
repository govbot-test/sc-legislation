  "abstracts": [
    {
      "note": "description",
      "abstract": "A CONCURRENT RESOLUTION TO FIX ONE P.M. ON MARCH 4, 2026, AS THE TIME TO ELECT A MEMBER TO THE PUBLIC SERVICE COMMISSION FOR THE FIRST CONGRESSIONAL DISTRICT FOR A TERM EXPIRING ON JUNE 30, 2028; TO ELECT A MEMBER TO THE PUBLIC SERVICE COMMISSION FOR THE THIRD CONGRESSIONAL DISTRICT FOR A TERM EXPIRING ON JUNE 30, 2028; TO ELECT A MEMBER TO THE PUBLIC SERVICE COMMISSION FOR THE FIFTH CONGRESSIONAL DISTRICT FOR A TERM EXPIRING ON JUNE 30, 2028; AND TO ELECT A MEMBER TO THE PUBLIC SERVICE COMMISSION FOR THE SEVENTH CONGRESSIONAL DISTRICT FOR A TERM EXPIRING ON JUNE 30, 2028."
    }
  ],
