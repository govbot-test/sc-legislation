  ],
  "subject": [],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A BILL TO AMEND THE SOUTH CAROLINA CODE OF LAWS BY ADDING SECTION 7-19-35 SO AS TO ESTABLISH THE ELECTION DISTRICTS FROM WHICH MEMBERS OF THE U.S. HOUSE OF REPRESENTATIVES ARE ELECTED; AND BY REPEALING SECTION 7-19-45 RELATING TO ELECTION DISTRICTS FROM WHICH MEMBERS OF THE U.S. HOUSE OF REPRESENTATIVES WERE FORMERLY ELECTED."
    }
  ],
